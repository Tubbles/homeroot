{
    "colorcolumn": [72, 80, 120],
    "colorscheme": "one-dark-j",
    "filemanager.showhidden": true,
    "ft:json": {
        "aspell.check": "on"
    },
    "hlsearch": true,
    "hlselection": true,
    "ignorecase": false,
    "lockbindings": true,
    "lsp.server": "python=pylsp,go=gopls,typescript=deno lsp,javascript=deno lsp,json=deno lsp,rust=rust-analyzer,c++=clangd,c=clangd,lua=lua-language-server",
    "matchbracestyle": "highlight",
    "mkparents": true,
    "parsecursor": true,
    "paste": true,
    "pathdisplay": "smart",
    "quittoscratch": true,
    "rmtrailingws": true,
    "savecursor": true,
    "saveundo": true,
    "showchars": "tab=\u003e,space= ,itab=|\u003e,ispace=|",
    "softwrap": true,
    "statusformatl": "$(modified)$(overwrite) $(opt:filetype) | $(opt:fileformat) | $(opt:encoding)",
    "statusformatr": " $(icase.indicator) | $(line),$(col)",
    "tabstospaces": true,
    "textfilterselectword": false,
}
