#!/usr/bin/env bash

# Check that _my_dir is not already defined
test -n "${_my_dir:-}" && echo "Error: _my_dir is already defined" && exit 1

# Get the directory of this script, even when sourced
_my_dir="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

# TODO : This wont work if some other config file redefines docker_home after this has been set..

_check_and_add() {
    local source="$1"
    local dest="$2"
    if [[ -d "${source}" ]]; then
        extra_run_flags+=(
            --volume "${source}:${dest}:ro,z"
        )
    fi
}

extra_run_flags+=(
    --env "MCONTAINER=CONTAINER"

    --volume "${HOME}/.bashrc:${docker_home}/.bashrc:ro,z"
    --volume "${HOME}/.bin:${docker_home}/.bin:ro,z"
    --volume "${HOME}/.config/bashrc.d:${docker_home}/.config/bashrc.d:ro,z"
    --volume "${HOME}/.git-prompt.sh:${docker_home}/.git-prompt.sh:ro,z"
    --volume "${HOME}/.gitconfig:${docker_home}/.gitconfig:ro,z"
    --volume "${HOME}/.install/bash_env.source:${docker_home}/.install/bash_env.source:ro,z"
    --volume "${HOME}/.install/git-prompt.source:${docker_home}/.install/git-prompt.source:ro,z"

    --volume "${HOME}/scr/setup_inside_container.sh:${docker_home}/scr/setup_inside_container.sh:ro,z"
)

_check_and_add "${HOME}/.ssh" "${docker_home}/.ssh"
# _check_and_add "/usr/local" "/usr/local"

if [[ -r "${_my_dir}/.dockerenv_extra" ]]; then
    source "${_my_dir}/.dockerenv_extra"
fi

if [[ -r "${_my_dir}/ghtoken" ]]; then
    extra_build_flags+=("--secret id=GH_TOKEN,src=${_my_dir}/ghtoken")
fi

# Clean up
unset _my_dir _check_and_add
